// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Student {
  id                  String             @id @default(cuid())
  clerkUserId         String             @unique
  clerkOrganizationId String
  fullName            String
  email               String
  phone               String?
  guardianName        String?
  guardianPhone       String?
  archivedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  batches             BatchStudent[]
  attendance          AttendanceRecord[]
  examResults         ExamResult[]

  @@unique([clerkOrganizationId, email])
  @@index([clerkOrganizationId])
  @@index([clerkOrganizationId, archivedAt])
  @@index([clerkOrganizationId, fullName])
}

model Batch {
  id                  String          @id @default(cuid())
  clerkOrganizationId String
  name                String
  subject             String?
  archivedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  students            BatchStudent[]
  schedules           BatchSchedule[]
  sessions            BatchSession[]
  exams               Exam[]

  @@index([clerkOrganizationId])
  @@index([clerkOrganizationId, archivedAt])
  @@index([clerkOrganizationId, name])
}

model BatchSchedule {
  id           String @id @default(cuid())
  batchId      String
  dayOfWeek    Int // 0-6
  startMinutes Int
  endMinutes   Int
  batch        Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model BatchStudent {
  batchId   String
  studentId String

  joinedAt DateTime @default(now())

  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([batchId, studentId])
  @@index([studentId])
}

model BatchSession {
  id         String             @id @default(cuid())
  batchId    String
  classDate  DateTime
  topic      String?
  summary    String?
  createdAt  DateTime           @default(now())
  batch      Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  attendance AttendanceRecord[]

  @@unique([batchId, classDate])
  @@index([batchId])
  @@index([batchId, classDate])
}

model AttendanceRecord {
  sessionId String
  studentId String

  status AttendanceStatus

  remarks String?

  session BatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([sessionId, studentId])
  @@index([studentId])
}

model Exam {
  id         String       @id @default(cuid())
  batchId    String
  title      String
  totalMarks Int
  examDate   DateTime
  createdAt  DateTime     @default(now())
  batch      Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  results    ExamResult[]

  @@unique([batchId, title])
  @@index([batchId])
  @@index([batchId, examDate])
}

model ExamResult {
  examId    String
  studentId String

  marks Float

  remarks String?

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([examId, studentId])
  @@index([studentId])
}
